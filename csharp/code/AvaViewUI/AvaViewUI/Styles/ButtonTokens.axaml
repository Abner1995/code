<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========== 颜色映射（引用 Palette） ========== -->

    <!-- 前景色：各颜色类 -->
    <StaticResource x:Key="ButtonDefaultPrimaryForeground" ResourceKey="AvaColorPrimary" />
    <StaticResource x:Key="ButtonDefaultSecondaryForeground" ResourceKey="AvaColorSecondary" />
    <StaticResource x:Key="ButtonDefaultTertiaryForeground" ResourceKey="AvaTextColorPrimary" />
    <StaticResource x:Key="ButtonDefaultSuccessForeground" ResourceKey="AvaColorSuccess" />
    <StaticResource x:Key="ButtonDefaultWarningForeground" ResourceKey="AvaColorWarning" />
    <StaticResource x:Key="ButtonDefaultDangerForeground" ResourceKey="AvaColorDanger" />
    <StaticResource x:Key="ButtonDefaultDisabledForeground" ResourceKey="AvaTextColorDisabled" />

    <!-- 默认背景 -->
    <StaticResource x:Key="ButtonDefaultBackground" ResourceKey="AvaFillColor0" />
    <StaticResource x:Key="ButtonDefaultPointeroverBackground" ResourceKey="AvaFillColor1" />
    <StaticResource x:Key="ButtonDefaultPressedBackground" ResourceKey="AvaFillColor2" />

    <!-- 边框（Light 主题全透明） -->
    <SolidColorBrush x:Key="ButtonDefaultBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ButtonDefaultPointeroverBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ButtonDefaultPressedBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ButtonDefaultDisabledBorderBrush" Color="Transparent" />

    <!-- ========== 尺寸 ========== -->
    <x:Double x:Key="ButtonDefaultHeight">32</x:Double>
    <x:Double x:Key="ButtonDefaultFontSize">14</x:Double>
    <FontWeight x:Key="ButtonDefaultFontWeight">Bold</FontWeight>
    <Thickness x:Key="ButtonDefaultPadding">12 0</Thickness>
    <Thickness x:Key="ButtonBorderThickness">1</Thickness>
    <CornerRadius x:Key="ButtonCornerRadius">3</CornerRadius>

</ResourceDictionary>
