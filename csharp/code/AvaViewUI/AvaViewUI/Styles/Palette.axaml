<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== Color 定义（原始色值） ==================== -->

    <!-- Blue -->
    <Color x:Key="AvaBlue2Color">#98CDFD</Color>
    <Color x:Key="AvaBlue5Color">#0064FA</Color>
    <Color x:Key="AvaBlue6Color">#0062D6</Color>
    <Color x:Key="AvaBlue7Color">#004FB3</Color>

    <!-- LightBlue -->
    <Color x:Key="AvaLightBlue2Color">#95D8F8</Color>
    <Color x:Key="AvaLightBlue5Color">#0095EE</Color>
    <Color x:Key="AvaLightBlue6Color">#007BCA</Color>
    <Color x:Key="AvaLightBlue7Color">#0063A7</Color>

    <!-- Green -->
    <Color x:Key="AvaGreen2Color">#A4E0A7</Color>
    <Color x:Key="AvaGreen5Color">#3BB346</Color>
    <Color x:Key="AvaGreen6Color">#30953B</Color>
    <Color x:Key="AvaGreen7Color">#25772F</Color>

    <!-- Orange -->
    <Color x:Key="AvaOrange5Color">#FC8800</Color>
    <Color x:Key="AvaOrange6Color">#D26700</Color>
    <Color x:Key="AvaOrange7Color">#A84A00</Color>

    <!-- Red -->
    <Color x:Key="AvaRed5Color">#F93920</Color>
    <Color x:Key="AvaRed6Color">#D52515</Color>
    <Color x:Key="AvaRed7Color">#B2140C</Color>

    <!-- Grey -->
    <Color x:Key="AvaGrey1Color">#E6E8EA</Color>
    <Color x:Key="AvaGrey5Color">#6B7075</Color>
    <Color x:Key="AvaGrey6Color">#555B61</Color>
    <Color x:Key="AvaGrey7Color">#41464C</Color>
    <Color x:Key="AvaGrey8Color">#2E3238</Color>
    <Color x:Key="AvaGrey9Color">#1C1F23</Color>

    <Color x:Key="AvaAIPurple1Color">#F2DAFF</Color>
    <Color x:Key="AvaAIPurple2Color">#E3B5FF</Color>
    <Color x:Key="AvaAIPurple3Color">#D191FF</Color>
    <Color x:Key="AvaAIPurple4Color">#BD6CFF</Color>
    <Color x:Key="AvaAIPurple5Color">#A647FF</Color>
    <Color x:Key="AvaAIPurple6Color">#8636DB</Color>
    <Color x:Key="AvaAIPurple7Color">#6928B8</Color>
    <Color x:Key="AvaAIPurple8Color">#4E1C94</Color>
    <Color x:Key="AvaAIPurple9Color">#361270</Color>

    <!-- ==================== 语义 Brush（按用途引用 Color） ==================== -->

    <!-- Primary -->
    <SolidColorBrush x:Key="AvaColorPrimary" Color="{StaticResource AvaBlue5Color}" />
    <SolidColorBrush x:Key="AvaColorPrimaryHover" Color="{StaticResource AvaBlue6Color}" />
    <SolidColorBrush x:Key="AvaColorPrimaryPressed" Color="{StaticResource AvaBlue7Color}" />
    <SolidColorBrush x:Key="AvaColorPrimaryDisabled" Color="{StaticResource AvaBlue2Color}" />

    <!-- Secondary -->
    <SolidColorBrush x:Key="AvaColorSecondary" Color="{StaticResource AvaLightBlue5Color}" />
    <SolidColorBrush x:Key="AvaColorSecondaryHover" Color="{StaticResource AvaLightBlue6Color}" />
    <SolidColorBrush x:Key="AvaColorSecondaryPressed" Color="{StaticResource AvaLightBlue7Color}" />
    <SolidColorBrush x:Key="AvaColorSecondaryDisabled" Color="{StaticResource AvaLightBlue2Color}" />

    <!-- Tertiary -->
    <SolidColorBrush x:Key="AvaColorTertiary" Color="{StaticResource AvaGrey5Color}" />
    <SolidColorBrush x:Key="AvaColorTertiaryHover" Color="{StaticResource AvaGrey6Color}" />
    <SolidColorBrush x:Key="AvaColorTertiaryPressed" Color="{StaticResource AvaGrey7Color}" />

    <!-- Success -->
    <SolidColorBrush x:Key="AvaColorSuccess" Color="{StaticResource AvaGreen5Color}" />
    <SolidColorBrush x:Key="AvaColorSuccessHover" Color="{StaticResource AvaGreen6Color}" />
    <SolidColorBrush x:Key="AvaColorSuccessPressed" Color="{StaticResource AvaGreen7Color}" />
    <SolidColorBrush x:Key="AvaColorSuccessDisabled" Color="{StaticResource AvaGreen2Color}" />

    <!-- Warning -->
    <SolidColorBrush x:Key="AvaColorWarning" Color="{StaticResource AvaOrange5Color}" />
    <SolidColorBrush x:Key="AvaColorWarningHover" Color="{StaticResource AvaOrange6Color}" />
    <SolidColorBrush x:Key="AvaColorWarningPressed" Color="{StaticResource AvaOrange7Color}" />

    <!-- Danger -->
    <SolidColorBrush x:Key="AvaColorDanger" Color="{StaticResource AvaRed5Color}" />
    <SolidColorBrush x:Key="AvaColorDangerHover" Color="{StaticResource AvaRed6Color}" />
    <SolidColorBrush x:Key="AvaColorDangerPressed" Color="{StaticResource AvaRed7Color}" />

    <!-- Text -->
    <SolidColorBrush x:Key="AvaTextColorPrimary" Opacity="0.8" Color="{StaticResource AvaGrey9Color}" />
    <SolidColorBrush x:Key="AvaTextColorSecondary" Opacity="0.62" Color="{StaticResource AvaGrey9Color}" />
    <SolidColorBrush x:Key="AvaTextColorDisabled" Opacity="0.35" Color="{StaticResource AvaGrey9Color}" />

    <!-- Fill -->
    <SolidColorBrush x:Key="AvaFillColor0" Opacity="0.05" Color="{StaticResource AvaGrey8Color}" />
    <SolidColorBrush x:Key="AvaFillColor1" Opacity="0.09" Color="{StaticResource AvaGrey8Color}" />
    <SolidColorBrush x:Key="AvaFillColor2" Opacity="0.13" Color="{StaticResource AvaGrey8Color}" />

    <!-- Border & Misc -->
    <SolidColorBrush x:Key="AvaColorWhite" Color="White" />
    <SolidColorBrush x:Key="AvaBorderColor" Opacity="0.08" Color="{StaticResource AvaGrey9Color}" />
    <SolidColorBrush x:Key="AvaDisabledBackgroundColor" Color="{StaticResource AvaGrey1Color}" />

    <!-- AI General：紫→蓝 45° 对角渐变背景（Solid Primary / 彩色前景） -->
    <LinearGradientBrush x:Key="AvaColorAIGeneral" StartPoint="99%,93%" EndPoint="1%,7%">
        <GradientStop Offset="0.0" Color="#E945FF" />   <!-- 粉紫 -->
        <GradientStop Offset="0.3" Color="#A647FF" />   <!-- 蓝紫 -->
        <GradientStop Offset="0.6" Color="#6B61FF" />   <!-- 紫蓝 -->
        <GradientStop Offset="1.0" Color="#2E8CFF" />   <!-- 亮蓝 -->
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AvaColorAIGeneralPointerover" StartPoint="99%,93%" EndPoint="1%,7%">
        <GradientStop Offset="0.0" Color="#C235DB" />
        <GradientStop Offset="0.3" Color="#8636DB" />
        <GradientStop Offset="0.6" Color="#584DDB" />
        <GradientStop Offset="1.0" Color="#2172DB" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AvaColorAIGeneralActive" StartPoint="99%,93%" EndPoint="1%,7%">
        <GradientStop Offset="0.0" Color="#9D27B8" />
        <GradientStop Offset="0.3" Color="#6928B8" />
        <GradientStop Offset="0.6" Color="#473BB8" />
        <GradientStop Offset="1.0" Color="#1659B8" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AvaColorAIGeneralDisabled" StartPoint="99%,93%" EndPoint="1%,7%">
        <GradientStop Offset="0.0" Color="#FEB5FF" />
        <GradientStop Offset="0.3" Color="#E3B5FF" />
        <GradientStop Offset="0.6" Color="#C1C0FF" />
        <GradientStop Offset="1.0" Color="#ABD5FF" />
    </LinearGradientBrush>

    <!-- AI Purple -->
    <SolidColorBrush x:Key="AvaColorAIPurple" Color="{StaticResource AvaAIPurple5Color}" />
    <SolidColorBrush x:Key="AvaColorAIPurplePointerover" Color="{StaticResource AvaAIPurple6Color}" />
    <SolidColorBrush x:Key="AvaColorAIPurpleActive" Color="{StaticResource AvaAIPurple7Color}" />
    <SolidColorBrush x:Key="AvaColorAIPurpleDisabled" Color="{StaticResource AvaAIPurple2Color}" />

    <LinearGradientBrush x:Key="AvaAIGeneral0" StartPoint="99%,93%" EndPoint="1%,7%">
        <GradientStop Offset="0.0" Color="#FFF2FF" />
        <GradientStop Offset="0.3" Color="#F8EDFF" />
        <GradientStop Offset="0.6" Color="#F4F4FF" />
        <GradientStop Offset="1.0" Color="#EFF7FF" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AvaAIGeneral1" StartPoint="99%,93%" EndPoint="1%,7%">
        <GradientStop Offset="0.0" Color="#FFDAFE" />
        <GradientStop Offset="0.3" Color="#F2DAFF" />
        <GradientStop Offset="0.6" Color="#DFE0FF" />
        <GradientStop Offset="1.0" Color="#D5EBFF" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AvaAIGeneral2" StartPoint="99%,93%" EndPoint="1%,7%">
        <GradientStop Offset="0.0" Color="#FEB5FF" />
        <GradientStop Offset="0.3" Color="#E3B5FF" />
        <GradientStop Offset="0.6" Color="#C1C0FF" />
        <GradientStop Offset="1.0" Color="#ABD5FF" />
    </LinearGradientBrush>

</ResourceDictionary>
