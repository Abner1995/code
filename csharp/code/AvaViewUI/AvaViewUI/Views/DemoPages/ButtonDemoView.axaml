<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaViewUI.Views.DemoPages.ButtonDemoView">

    <StackPanel Margin="16" Spacing="16">
        <WrapPanel>
            <Button Margin="4" Content="Default" />
            <Button Margin="4" Content="Primary" Classes="Primary" />
            <Button Margin="4" Content="Secondary" Classes="Secondary" />
            <Button Margin="4" Content="Tertiary" Classes="Tertiary" />
            <Button Margin="4" Content="Success" Classes="Success" />
            <Button Margin="4" Content="Warning" Classes="Warning" />
            <Button Margin="4" Content="Danger" Classes="Danger" />
            <Button Margin="4" Content="Disabled" Classes="Danger" IsEnabled="False" />
        </WrapPanel>
    </StackPanel>

</UserControl>
